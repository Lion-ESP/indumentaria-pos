meta {
  name: Consultar balance
  type: http
  seq: 1
}

get {
  url: {{base_url}}/reports/balance?from_date=2020-01-01&to_date=2099-12-31&group_by=day
  auth: none
}

params:query {
  from_date: 2020-01-01
  to_date: 2099-12-31
  group_by: day
}

assert {
  res.status: eq 200
}

tests {
  test("status 200", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("estructura BalanceResponse", function () {
    const body = res.getBody();
    expect(body).to.include.all.keys("total_gross_profit", "total_net_profit", "buckets");
  });
}
