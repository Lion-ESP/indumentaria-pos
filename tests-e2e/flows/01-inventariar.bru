meta {
  name: Flujo - 1) Inventariar
  type: http
  seq: 1
}

post {
  url: {{base_url}}/products
  body: json
  auth: none
}

body:json {
  {
    "sku": "FLOW-REM-001",
    "name": "Remera (flujo)",
    "unit": "unit",
    "cost_price": "60.00",
    "sale_price": "100.00",
    "initial_stock": "10"
  }
}

assert {
  res.status: eq 201
}

script:post-response {
  bru.setVar("product_id", res.getBody().id);
}

tests {
  test("se creó el producto y se capturó su id", function () {
    expect(res.getStatus()).to.equal(201);
    expect(bru.getVar("product_id")).to.be.a("string");
  });
}
