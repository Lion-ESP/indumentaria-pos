meta {
  name: Consultar producto
  type: http
  seq: 2
}

get {
  url: {{base_url}}/products/{{product_id}}
  auth: none
}

assert {
  res.status: eq 200
}

tests {
  test("status 200", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("estructura ProductResponse", function () {
    const body = res.getBody();
    expect(body).to.include.all.keys("id", "sku", "stock");
  });

  test("devuelve el producto creado", function () {
    expect(res.getBody().id).to.equal(bru.getVar("product_id"));
  });
}
